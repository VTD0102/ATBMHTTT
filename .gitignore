# E-commerce Security Demo - Gitignore
# Exclude generated simulation data and artifacts

# Simulation Output
website/
quarantine/
backup/
logs/
.claude/
./*.log
backups/
# Optional: Shell script temporary files
*.tmp
*.log
venv/
# System/IDE Files
.DS_Store
Thumbs.db
.vscode/
.idea/
.venv*/
venv/
*.swp
*~
__pycache__/
*.pyc
*.pyd


# ClamAV Database (if updated locally)
main.cvd
daily.cvd
bytecode.cvd
freshclam.log

# Ransomware demo sandbox artifacts
ransomware-demo/attacker/sandbox/*.encrypted
ransomware-demo/attacker/sandbox/.ransom_key
ransomware-demo/backups/
backups/

# Thư viện Node.js
node_modules/

# Thư mục build / output
dist/
build/
.next/
out/

# Các file debug/log của Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*
